---
import Analytics from '@vercel/analytics/astro';
import SEO from '../components/SEO.astro';
import StructuredData from '../components/StructuredData.astro';
import { getLocaleFromUrl, getLocalePath, type Locale } from '../i18n/index';
import '../styles/v4.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  structuredDataType?: 'WebSite' | 'SoftwareApplication' | 'Organization';
  locale?: Locale;
}

const {
  title,
  description,
  image,
  structuredDataType = 'WebSite',
  locale: propLocale,
} = Astro.props;

const locale = propLocale ?? getLocaleFromUrl(Astro.url);
const currentPath = Astro.url.pathname.replace(/^\/fr/, '') || '/';
const enUrl = `https://gostoa.dev${getLocalePath(currentPath, 'en')}`;
const frUrl = `https://gostoa.dev${getLocalePath(currentPath, 'fr')}`;
---

<!doctype html>
<html lang={locale === 'fr' ? 'fr' : 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <SEO title={title} description={description} image={image} locale={locale} />
    <StructuredData type={structuredDataType} />

    <!-- hreflang tags for i18n SEO -->
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="fr" href={frUrl} />
    <link rel="alternate" hreflang="x-default" href={enUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="32x32" href="/favicon-32x32.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Source+Code+Pro:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
    <Analytics />
    <script src="../scripts/v4.js"></script>
  </body>
</html>
