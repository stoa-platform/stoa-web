---
import Analytics from '@vercel/analytics/astro';
import SEO from '../components/SEO.astro';
import StructuredData from '../components/StructuredData.astro';
import '../styles/v4.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  structuredDataType?: 'WebSite' | 'SoftwareApplication' | 'Organization';
}

const {
  title,
  description,
  image,
  structuredDataType = 'WebSite'
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <SEO title={title} description={description} image={image} />
    <StructuredData type={structuredDataType} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Source+Code+Pro:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
    <Analytics />
    <script src="../scripts/v4.js"></script>
  </body>
</html>
