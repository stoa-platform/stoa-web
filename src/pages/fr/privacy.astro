---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('fr');
---

<Layout
  title={t('privacy.title')}
  description={t('privacy.description')}
>
  <Header />
  <main class="pt-24 pb-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl font-bold text-white mb-8">{t('privacy.heading')}</h1>
      <p class="text-sm text-gray-500 mb-8">{t('privacy.lastUpdated')}</p>

      <div class="prose prose-invert prose-gray max-w-none space-y-8 text-gray-300 text-sm leading-relaxed">
        <section>
          <h2 class="text-xl font-semibold text-white mb-3">{t('privacy.section1.title')}</h2>
          <p set:html={t('privacy.section1.text')} />
        </section>

        <section>
          <h2 class="text-xl font-semibold text-white mb-3">{t('privacy.section2.title')}</h2>
          <p set:html={t('privacy.section2.analytics')} />
          <p set:html={t('privacy.section2.newsletter')} />
          <p set:html={t('privacy.section2.accounts')} />
          <p set:html={t('privacy.section2.contact')} />
        </section>

        <section>
          <h2 class="text-xl font-semibold text-white mb-3">{t('privacy.section3.title')}</h2>
          <ul class="list-disc list-inside space-y-2 text-gray-400">
            <li>{t('privacy.section3.item1')}</li>
            <li>{t('privacy.section3.item2')}</li>
            <li>{t('privacy.section3.item3')}</li>
            <li>{t('privacy.section3.item4')}</li>
          </ul>
          <p class="mt-3">{t('privacy.section3.note')}</p>
        </section>

        <section>
          <h2 class="text-xl font-semibold text-white mb-3">{t('privacy.section4.title')}</h2>
          <p>{t('privacy.section4.text')}</p>
        </section>

        <section>
          <h2 class="text-xl font-semibold text-white mb-3">{t('privacy.section5.title')}</h2>
          <p>{t('privacy.section5.intro')}</p>
          <ul class="list-disc list-inside space-y-2 text-gray-400 mt-2">
            <li>{t('privacy.section5.item1')}</li>
            <li>{t('privacy.section5.item2')}</li>
            <li>{t('privacy.section5.item3')}</li>
            <li>{t('privacy.section5.item4')}</li>
            <li>{t('privacy.section5.item5')}</li>
          </ul>
          <p class="mt-3">
            {t('privacy.section5.contact')}{' '}
            <a href="mailto:privacy@gostoa.dev" class="text-primary-400 hover:text-primary-300">privacy@gostoa.dev</a>.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-semibold text-white mb-3">{t('privacy.section6.title')}</h2>
          <p>{t('privacy.section6.text')}</p>
        </section>

        <section>
          <h2 class="text-xl font-semibold text-white mb-3">{t('privacy.section7.title')}</h2>
          <p>
            {t('privacy.section7.text')}{' '}
            <a href="mailto:privacy@gostoa.dev" class="text-primary-400 hover:text-primary-300">privacy@gostoa.dev</a>
          </p>
          <p class="mt-2">{t('privacy.section7.company')}</p>
        </section>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
