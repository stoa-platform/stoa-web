---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import WhySection from '../components/WhySection.astro';
import AudienceSection from '../components/AudienceSection.astro';
import ValueProps from '../components/ValueProps.astro';
import Features from '../components/Features.astro';
import Comparison from '../components/Comparison.astro';
import Pricing from '../components/Pricing.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="STOA - European Agent Gateway | MCP Protocol & AI-Native API Management"
  description="The first gateway built for AI agents. Native MCP Protocol support, token metering, European sovereignty. Open source Agent Gateway for Model Context Protocol."
  structuredDataType="SoftwareApplication"
>
  <Header />
  <main>
    <Hero />
    <WhySection />
    <AudienceSection />
    <ValueProps />
    <Features />
    <Comparison />
    <Pricing />
    <FinalCTA />
  </main>
  <Footer />
</Layout>
