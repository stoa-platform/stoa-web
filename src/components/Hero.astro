---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-primary-950/20 via-gray-950 to-gray-950"></div>

  <!-- Animated grid background -->
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#1f2937_1px,transparent_1px),linear-gradient(to_bottom,#1f2937_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_110%)]"></div>

  <!-- Glow orbs -->
  <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-primary-600/20 rounded-full blur-3xl animate-pulse-slow"></div>
  <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-purple-600/20 rounded-full blur-3xl animate-pulse-slow" style="animation-delay: 1s;"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <!-- Badge -->
    <div class="inline-flex items-center space-x-2 bg-gray-800/50 border border-gray-700/50 rounded-full px-4 py-2 mb-8 animate-fade-in">
      <span class="text-sm font-medium">🇪🇺</span>
      <span class="text-sm text-gray-300 font-medium">European Sovereign</span>
      <span class="text-gray-600">•</span>
      <span class="text-sm text-gray-300 font-medium">Open Source</span>
      <span class="text-gray-600">•</span>
      <span class="text-sm text-gray-300 font-medium">Apache 2.0</span>
    </div>

    <!-- Main headline -->
    <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold tracking-tight mb-6 animate-slide-up">
      <span class="text-white">The European</span>
      <br />
      <span class="gradient-text">Agent Gateway</span>
    </h1>

    <!-- Subtitle -->
    <p class="text-lg sm:text-xl text-gray-400 max-w-3xl mx-auto mb-4 animate-slide-up" style="animation-delay: 0.1s;">
      API Gateways were built for human developers. STOA is a gateway purpose-built for AI agents. One contract, all protocols — sovereign, open-source, with NIS2/DORA supportive features.**
    </p>

    <!-- Subtext -->
    <p class="text-sm text-gray-500 mb-10 animate-slide-up" style="animation-delay: 0.15s;">
      European hosting available.* No vendor lock-in. Built by API management practitioners.
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16 animate-slide-up" style="animation-delay: 0.2s;">
      <a
        href="https://console.gostoa.dev"
        class="group relative inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-white bg-primary-600 rounded-xl hover:bg-primary-500 transition-all duration-300 glow"
      >
        <span>Try STOA Free</span>
        <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
      <a
        href="https://github.com/stoa-platform"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-gray-300 bg-gray-800/50 border border-gray-700 rounded-xl hover:bg-gray-800 hover:border-gray-600 transition-all duration-300"
      >
        <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
          <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
        </svg>
        <span>View on GitHub</span>
      </a>
    </div>

    <!-- Terminal Animation -->
    <div class="max-w-3xl mx-auto animate-slide-up" style="animation-delay: 0.3s;">
      <div class="bg-gray-900 rounded-xl border border-gray-800 shadow-2xl overflow-hidden">
        <!-- Terminal header -->
        <div class="flex items-center space-x-2 px-4 py-3 bg-gray-800/50 border-b border-gray-800">
          <div class="w-3 h-3 rounded-full bg-red-500"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
          <div class="w-3 h-3 rounded-full bg-green-500"></div>
          <span class="ml-4 text-sm text-gray-500 font-mono">terminal</span>
        </div>

        <!-- Terminal content -->
        <div class="p-6 font-mono text-sm text-left">
          <div class="space-y-3">
            <div class="flex items-start">
              <span class="text-green-400 mr-2">$</span>
              <span class="text-gray-300" id="typing-command"></span>
              <span class="inline-block w-2 h-5 bg-primary-500 ml-1 animate-pulse" id="cursor"></span>
            </div>
            <div id="output-container" class="hidden">
              <div class="text-gray-500 mt-4">Starting STOA Platform...</div>
              <div class="mt-2 text-primary-400">
                <span class="text-green-400">✓</span> Control Plane API started
              </div>
              <div class="text-primary-400">
                <span class="text-green-400">✓</span> MCP Gateway initialized
              </div>
              <div class="text-primary-400">
                <span class="text-green-400">✓</span> Developer Portal ready
              </div>
              <div class="mt-4 text-white">
                <span class="text-green-400">Ready!</span> STOA is running at <span class="text-primary-400">http://localhost:8000</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </div>
</section>

<script>
  const command = 'docker compose up -d';
  const typingElement = document.getElementById('typing-command');
  const cursor = document.getElementById('cursor');
  const outputContainer = document.getElementById('output-container');
  let index = 0;

  function typeCommand() {
    if (index < command.length) {
      typingElement!.textContent += command.charAt(index);
      index++;
      setTimeout(typeCommand, 50 + Math.random() * 50);
    } else {
      setTimeout(() => {
        cursor?.classList.add('hidden');
        outputContainer?.classList.remove('hidden');
      }, 500);
    }
  }

  // Start typing after a delay
  setTimeout(typeCommand, 1000);
</script>
