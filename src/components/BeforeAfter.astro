---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const before = [
  t('beforeAfter.before.item1'),
  t('beforeAfter.before.item2'),
  t('beforeAfter.before.item3'),
  t('beforeAfter.before.item4'),
  t('beforeAfter.before.item5'),
];
const after = [
  t('beforeAfter.after.item1'),
  t('beforeAfter.after.item2'),
  t('beforeAfter.after.item3'),
  t('beforeAfter.after.item4'),
  t('beforeAfter.after.item5'),
];
---

<section class="before-after" id="before-after" aria-label="Before and After STOA">
  <div class="section-container">
    <div class="section-header reveal" data-reveal>
      <span class="section-tag">{t('beforeAfter.tag')}</span>
      <h2 class="section-title" set:html={t('beforeAfter.title')} />
      <p class="section-desc">{t('beforeAfter.description')}</p>
    </div>

    <div class="ba-grid" data-stagger-parent>
      <div class="ba-col">
        <span class="ba-col-title ba-before-title">{t('beforeAfter.before.title')}</span>
        {before.map((item, i) => (
          <div class={`ba-item ba-item-before stagger-child`} data-stagger={i}>{item}</div>
        ))}
      </div>

      <div class="ba-arrow">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14" /><path d="M12 5l7 7-7 7" />
        </svg>
      </div>

      <div class="ba-col">
        <span class="ba-col-title ba-after-title">{t('beforeAfter.after.title')}</span>
        {after.map((item, i) => (
          <div class={`ba-item ba-item-after stagger-child`} data-stagger={i + 5}>{item}</div>
        ))}
      </div>
    </div>
  </div>
</section>
