---
import { getLocaleFromUrl, t } from '../i18n/index';

const locale = getLocaleFromUrl(Astro.url);
const i18n = t(locale);
---

<section class="before-after" id="before-after" aria-label="Before and After STOA">
  <div class="section-container">
    <div class="section-header reveal" data-reveal>
      <span class="section-tag">{i18n.beforeAfter.sectionTag}</span>
      <h2 class="section-title" set:html={i18n.beforeAfter.title} />
      <p class="section-desc">{i18n.beforeAfter.desc}</p>
    </div>

    <div class="ba-grid" data-stagger-parent>
      <div class="ba-col">
        <span class="ba-col-title ba-before-title">{i18n.beforeAfter.beforeTitle}</span>
        {i18n.beforeAfter.before.map((item: string, i: number) => (
          <div class={`ba-item ba-item-before stagger-child`} data-stagger={i}>{item}</div>
        ))}
      </div>

      <div class="ba-arrow">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14" /><path d="M12 5l7 7-7 7" />
        </svg>
      </div>

      <div class="ba-col">
        <span class="ba-col-title ba-after-title">{i18n.beforeAfter.afterTitle}</span>
        {i18n.beforeAfter.after.map((item: string, i: number) => (
          <div class={`ba-item ba-item-after stagger-child`} data-stagger={i + 5}>{item}</div>
        ))}
      </div>
    </div>
  </div>
</section>
