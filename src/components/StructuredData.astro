---
// Structured Data (JSON-LD) for SEO
// Helps search engines understand the page content

interface Props {
  type?: 'WebSite' | 'SoftwareApplication' | 'Organization';
}

const { type = 'WebSite' } = Astro.props;

const websiteData = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "STOA Platform",
  "alternateName": ["STOA Gateway", "STOA Agent Gateway", "STOA MCP Gateway"],
  "url": "https://gostoa.dev",
  "description": "The European Agent Gateway - First gateway built for AI agents with native MCP Protocol support, token metering, and European sovereignty.",
  "keywords": "MCP gateway, Agent Gateway, Model Context Protocol, AI gateway, European API gateway",
  "inLanguage": "en",
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "https://docs.gostoa.dev/search?q={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
};

const softwareData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "STOA Platform",
  "alternateName": ["STOA Gateway", "STOA Agent Gateway", "STOA MCP Gateway"],
  "operatingSystem": "Linux, Kubernetes",
  "applicationCategory": "DeveloperApplication",
  "applicationSubCategory": "API Gateway, MCP Gateway, Agent Gateway",
  "description": "The first gateway built for AI agents. Native MCP Protocol support, token metering, European sovereignty.",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "EUR",
    "description": "Open Source - Apache 2.0 License"
  },
  "author": {
    "@type": "Organization",
    "name": "STOA Platform",
    "url": "https://gostoa.dev",
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "FR"
    }
  },
  "downloadUrl": "https://github.com/stoa-platform/stoa",
  "softwareVersion": "0.1.0",
  "releaseNotes": "https://github.com/stoa-platform/stoa/releases",
  "screenshot": "https://gostoa.dev/og-image.png",
  "featureList": [
    "MCP Gateway - Native Model Context Protocol support for AI agents",
    "Agent Gateway - First-class AI agent traffic handling and governance",
    "Token Metering - Track AI token usage per tenant and team",
    "European Sovereign - EU-based, NIS2/DORA compliant, no CLOUD Act",
    "Universal Access Control - Same policies for REST APIs and MCP tools",
    "Multi-Protocol - REST, MCP, GraphQL, gRPC through one contract"
  ],
  "keywords": "MCP gateway, Agent Gateway, Model Context Protocol, AI gateway, token metering"
};

const organizationData = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "STOA Platform",
  "url": "https://gostoa.dev",
  "logo": "https://gostoa.dev/logo.png",
  "description": "European open-source company building the Agent Gateway for AI and MCP Protocol",
  "sameAs": [
    "https://github.com/stoa-platform",
    "https://discord.gg/j8tHSSes",
    "https://twitter.com/stoagateway",
    "https://linkedin.com/company/gostoa"
  ],
  "address": {
    "@type": "PostalAddress",
    "addressCountry": "FR"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "technical support",
    "url": "https://discord.gg/j8tHSSes",
    "email": "hello@gostoa.dev"
  }
};

const data = type === 'SoftwareApplication'
  ? softwareData
  : type === 'Organization'
    ? organizationData
    : websiteData;
---

<script type="application/ld+json" set:html={JSON.stringify(data)} />

{/* Add Organization schema alongside primary schema for comprehensive coverage */}
{type === 'SoftwareApplication' && (
  <script type="application/ld+json" set:html={JSON.stringify(organizationData)} />
)}
