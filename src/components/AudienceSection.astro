---
---

<section id="audiences" class="py-24 bg-gray-950">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">

      <!-- For Developers -->
      <div class="p-8 bg-gradient-to-br from-blue-900/30 to-gray-900 rounded-2xl border border-blue-800/30">
        <div class="flex items-center gap-3 mb-6">
          <span class="text-3xl">
            <svg class="w-8 h-8 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
          </span>
          <h3 class="text-2xl font-bold text-white">For Developers</h3>
        </div>
        <ul class="space-y-4 text-gray-300">
          <li class="flex gap-3">
            <svg class="w-5 h-5 text-green-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span><strong class="text-white">CLI-first</strong> — Scriptable, AI-agent friendly</span>
          </li>
          <li class="flex gap-3">
            <svg class="w-5 h-5 text-green-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span><strong class="text-white">GitOps native</strong> — Config as code, ArgoCD ready</span>
          </li>
          <li class="flex gap-3">
            <svg class="w-5 h-5 text-green-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span><strong class="text-white">Local dev</strong> — Get started in minutes</span>
          </li>
          <li class="flex gap-3">
            <svg class="w-5 h-5 text-green-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span><strong class="text-white">Sensible defaults</strong> — No YAML hell</span>
          </li>
        </ul>
        <a href="https://docs.gostoa.dev/docs/guides/quick-start" class="inline-flex items-center mt-6 text-blue-400 hover:text-blue-300 font-medium transition-colors">
          Read the Quickstart
          <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>

      <!-- For Architects -->
      <div class="p-8 bg-gradient-to-br from-purple-900/30 to-gray-900 rounded-2xl border border-purple-800/30">
        <div class="flex items-center gap-3 mb-6">
          <span class="text-3xl">
            <svg class="w-8 h-8 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </span>
          <h3 class="text-2xl font-bold text-white">For Architects & CTOs</h3>
        </div>
        <ul class="space-y-4 text-gray-300">
          <li class="flex gap-3">
            <svg class="w-5 h-5 text-green-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span><strong class="text-white">Governance at scale</strong> — RBAC, audit, compliance</span>
          </li>
          <li class="flex gap-3">
            <svg class="w-5 h-5 text-green-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span><strong class="text-white">No vendor lock-in</strong> — Apache 2.0, run anywhere</span>
          </li>
          <li class="flex gap-3">
            <svg class="w-5 h-5 text-green-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span><strong class="text-white">AI cost control</strong> — Token metering per team</span>
          </li>
          <li class="flex gap-3">
            <svg class="w-5 h-5 text-green-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span><strong class="text-white">Future-proof</strong> — MCP-native architecture</span>
          </li>
        </ul>
        <a href="https://docs.gostoa.dev/docs/concepts/architecture" class="inline-flex items-center mt-6 text-purple-400 hover:text-purple-300 font-medium transition-colors">
          View Architecture
          <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>

    </div>
  </div>
</section>
