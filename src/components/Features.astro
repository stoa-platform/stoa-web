---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const cards = [
  {
    icon: 'mcp',
    color: '#10b981',
    title: t('featureCards.mcp.title'),
    metric: t('featureCards.mcp.metric'),
    desc: t('featureCards.mcp.desc'),
  },
  {
    icon: 'bridge',
    color: '#8b5cf6',
    title: t('featureCards.bridge.title'),
    metric: t('featureCards.bridge.metric'),
    desc: t('featureCards.bridge.desc'),
  },
  {
    icon: 'uac',
    color: '#2dd4bf',
    title: t('featureCards.uac.title'),
    metric: t('featureCards.uac.metric'),
    desc: t('featureCards.uac.desc'),
  },
  {
    icon: 'observability',
    color: '#f59e0b',
    title: t('featureCards.observability.title'),
    metric: t('featureCards.observability.metric'),
    desc: t('featureCards.observability.desc'),
  },
  {
    icon: 'portal',
    color: '#3b82f6',
    title: t('featureCards.portal.title'),
    metric: t('featureCards.portal.metric'),
    desc: t('featureCards.portal.desc'),
  },
];
---

<section class="features-v4" id="features" aria-label="Key features">
  <div class="features-header reveal" data-reveal>
    <span class="feature-tag">{t('featureCards.tag')}</span>
    <h2 class="features-section-title" set:html={t('featureCards.title')} />
  </div>

  <div class="feature-cards-grid">
    {cards.map((card, i) => (
      <div class={`feature-card feature-card-${card.icon} reveal`} data-reveal data-reveal-delay={String(i * 100)}>
        <div class="feature-card-icon" style={`--card-color: ${card.color}`}>
          {card.icon === 'mcp' && (
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5" fill="none"/><circle cx="12" cy="8" r="2" fill="currentColor"/><circle cx="8" cy="15" r="2" fill="currentColor"/><circle cx="16" cy="15" r="2" fill="currentColor"/><path d="M12 10v2M10 14l-1.5 1M14 14l1.5 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
          )}
          {card.icon === 'bridge' && (
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M4 12h5M15 12h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><rect x="9" y="7" width="6" height="10" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M11 10h2M11 12h2M11 14h2" stroke="currentColor" stroke-width="1" stroke-linecap="round"/></svg>
          )}
          {card.icon === 'uac' && (
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="4" y="4" width="16" height="16" rx="3" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M12 8v8M8 12h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="12" cy="12" r="2" fill="currentColor" opacity="0.3"/></svg>
          )}
          {card.icon === 'observability' && (
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M4 18l4-6 4 3 4-8 4 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="8" cy="12" r="1.5" fill="currentColor" opacity="0.3"/><circle cx="16" cy="7" r="1.5" fill="currentColor" opacity="0.3"/></svg>
          )}
          {card.icon === 'portal' && (
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M3 9h18" stroke="currentColor" stroke-width="1.5"/><circle cx="6" cy="7" r="0.75" fill="currentColor"/><circle cx="8.5" cy="7" r="0.75" fill="currentColor"/><path d="M7 13h5M7 16h10" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.6"/></svg>
          )}
        </div>
        <h3 class="feature-card-title">{card.title}</h3>
        <span class="feature-card-metric">{card.metric}</span>
        <p class="feature-card-desc">{card.desc}</p>
      </div>
    ))}
  </div>
</section>
