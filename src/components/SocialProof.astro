---
const stats = [
  { value: '559+', label: 'Automated Tests', detail: 'Cargo + Vitest + Pytest + E2E' },
  { value: '6', label: 'Gateway Integrations', detail: 'STOA, Kong, Gravitee, webMethods, Apigee, AWS' },
  { value: '101+', label: 'Documentation Pages', detail: 'Guides, ADRs, API Reference' },
  { value: '100%', label: 'Open Source', detail: 'Apache 2.0 — No BSL, No SSPL' },
];

const badges = [
  { icon: '🛡️', text: 'SOC 2 Type II Supportive' },
  { icon: '🇪🇺', text: 'NIS2 / DORA Supportive' },
  { icon: '🔓', text: 'Apache 2.0 Licensed' },
  { icon: '🏗️', text: 'Built in Public' },
];
---

<section class="py-20 bg-gray-950 border-t border-gray-800/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-12">
      <span class="text-primary-400 font-semibold text-sm uppercase tracking-wider">By the Numbers</span>
      <h2 class="text-3xl sm:text-4xl font-bold text-white mt-2 mb-4">
        Built for Production, <span class="gradient-text">Not for Demos</span>
      </h2>
      <p class="text-lg text-gray-400 max-w-2xl mx-auto">
        Real metrics from a real platform. No vanity numbers.
      </p>
    </div>

    <!-- Stats grid -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
      {stats.map((stat) => (
        <div class="relative group bg-gray-900/50 border border-gray-800 rounded-xl p-6 text-center hover:border-primary-600/50 transition-colors">
          <div class="text-3xl sm:text-4xl font-bold text-white mb-1">{stat.value}</div>
          <div class="text-sm font-semibold text-primary-400 mb-2">{stat.label}</div>
          <div class="text-xs text-gray-500">{stat.detail}</div>
        </div>
      ))}
    </div>

    <!-- Trust badges -->
    <div class="flex flex-wrap items-center justify-center gap-4">
      {badges.map((badge) => (
        <div class="inline-flex items-center space-x-2 bg-gray-900/50 border border-gray-800 rounded-full px-4 py-2">
          <span class="text-sm">{badge.icon}</span>
          <span class="text-xs text-gray-400 font-medium">{badge.text}</span>
        </div>
      ))}
    </div>
  </div>
</section>
