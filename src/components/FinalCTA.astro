---
---

<section id="get-started" class="py-24 bg-gradient-to-b from-gray-900 to-gray-950 relative overflow-hidden">
  <!-- Background effects -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-primary-600/5 rounded-full blur-3xl"></div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <!-- Heading -->
    <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
      Ready to Explore?
    </h2>

    <!-- Subtitle -->
    <p class="text-xl text-gray-400 max-w-2xl mx-auto mb-10">
      Join the community rethinking API management for the AI era.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-10">
      <a
        href="https://portal.gostoa.dev"
        class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-gray-900 bg-white rounded-xl hover:bg-gray-100 transition-all duration-300"
      >
        Try STOA Free
      </a>
      <a
        href="https://docs.gostoa.dev/docs/intro"
        class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-gray-300 border border-gray-600 rounded-xl hover:border-gray-400 hover:text-white transition-all duration-300"
      >
        Read the Docs
      </a>
    </div>

    <!-- Bottom text -->
    <p class="text-sm text-gray-500">
      Open Source • Apache 2.0 • Built in public
    </p>
  </div>
</section>
