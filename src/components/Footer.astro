---
import { getLocaleFromUrl, getLocalePath, t } from '../i18n/index';

const locale = getLocaleFromUrl(Astro.url);
const i18n = t(locale);
---

<footer class="footer-v4">
  <div class="footer-inner">
    <div class="footer-col">
      <a href="#" class="nav-logo">
        <svg width="24" height="24" viewBox="0 0 32 32">
          <defs><linearGradient id="logo-grad2" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" style="stop-color:#047857"/><stop offset="100%" style="stop-color:#059669"/></linearGradient></defs>
          <circle cx="16" cy="16" r="15" fill="url(#logo-grad2)"/>
          <path d="M10 11 Q10 8, 16 8 Q22 8, 22 11 Q22 14, 16 14 Q10 14, 10 17 Q10 20, 16 20 Q22 20, 22 24 Q22 27, 16 27" stroke="white" stroke-width="2.5" stroke-linecap="round" fill="none"/>
          <circle cx="8" cy="14" r="1.5" fill="white" opacity="0.8"/><circle cx="24" cy="14" r="1.5" fill="white" opacity="0.8"/>
          <circle cx="8" cy="20" r="1.5" fill="white" opacity="0.8"/><circle cx="24" cy="20" r="1.5" fill="white" opacity="0.8"/>
        </svg>
        <span>STOA</span>
      </a>
      <p class="footer-desc" set:html={i18n.footer.desc} />
    </div>
    <div class="footer-col">
      <h4>{i18n.footer.product}</h4>
      <a href="https://docs.gostoa.dev/docs/guides/quickstart">{i18n.footer.quickStart}</a>
      <a href="https://docs.gostoa.dev/docs/concepts/architecture">{i18n.footer.architecture}</a>
      <a href="https://docs.gostoa.dev/docs/api">{i18n.footer.apiReference}</a>
    </div>
    <div class="footer-col">
      <h4>{i18n.footer.community}</h4>
      <a href="https://github.com/stoa-platform/stoa">GitHub</a>
      <a href="https://docs.gostoa.dev/blog">{i18n.footer.blog}</a>
      <a href="https://docs.gostoa.dev/docs/community/philosophy">{i18n.footer.philosophy}</a>
    </div>
    <div class="footer-col">
      <h4>{i18n.footer.company}</h4>
      <a href="https://docs.gostoa.dev/docs/enterprise">{i18n.footer.enterprise}</a>
      <a href="https://docs.gostoa.dev/docs/community/faq">{i18n.footer.faq}</a>
      <a href="https://docs.gostoa.dev/legal/trademarks">{i18n.footer.trademarks}</a>
    </div>
  </div>
  <div class="footer-bottom">
    <span>{i18n.footer.copyright}</span>
  </div>
</footer>
