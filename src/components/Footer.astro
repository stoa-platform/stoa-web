---

<footer class="bg-gray-900 border-t border-gray-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Newsletter -->
    <div class="mb-12 pb-12 border-b border-gray-800">
      <div class="max-w-2xl mx-auto text-center">
        <h3 class="text-xl font-bold text-white mb-2">Stay in the loop</h3>
        <p class="text-gray-400 mb-6">Get updates on new features, releases, and API management insights.</p>
        <form
          action="https://buttondown.com/api/emails/embed-subscribe/cab-i"
          method="post"
          target="_blank"
          class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto"
        >
          <input
            type="email"
            name="email"
            placeholder="you@company.com"
            class="flex-1 px-4 py-3 bg-gray-800 border border-gray-700 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-600 focus:border-transparent"
            required
          />
          <button
            type="submit"
            class="px-6 py-3 bg-primary-600 hover:bg-primary-500 text-white font-semibold rounded-lg transition-colors"
          >
            Subscribe
          </button>
        </form>
      </div>
    </div>

    <!-- Links grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-8 mb-12">
      <div>
        <h4 class="text-white font-semibold mb-4">Product</h4>
        <ul class="space-y-3">
          {footerLinks.product.map((link) => (
            <li>
              <a href={link.href} class="text-gray-400 hover:text-white transition-colors text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="text-white font-semibold mb-4">Resources</h4>
        <ul class="space-y-3">
          {footerLinks.resources.map((link) => (
            <li>
              <a href={link.href} class="text-gray-400 hover:text-white transition-colors text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="text-white font-semibold mb-4">Community</h4>
        <ul class="space-y-3">
          {footerLinks.community.map((link) => (
            <li>
              <a href={link.href} class="text-gray-400 hover:text-white transition-colors text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Legal disclaimers -->
    <div class="mb-8 pt-8 border-t border-gray-800">
      <div class="space-y-3 text-xs text-gray-500">
        <p>
          *Data residency and jurisdiction depend on your deployment choice. Consult legal counsel for compliance advice.
        </p>
        <p>
          **<strong>Compliance Note:</strong> STOA provides features to support your NIS2 and DORA compliance efforts.
          Certification and audit responsibility remains with the implementing organization.
        </p>
        <p>
          Product names mentioned (Kong, Tyk, Gravitee, APISIX) are trademarks of their respective owners.
        </p>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col sm:flex-row items-center justify-between pt-8 border-t border-gray-800">
      <!-- Logo and copyright -->
      <div class="flex items-center space-x-3 mb-4 sm:mb-0">
        <div class="w-8 h-8 bg-primary-600 rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <span class="text-gray-400 text-sm">
          © {new Date().getFullYear()} STOA Platform. All rights reserved.
        </span>
      </div>

      <!-- Social links -->
      <div class="flex items-center space-x-4">
        {socialLinks.map((social) => (
          <a
            href={social.href}
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-400 hover:text-white transition-colors"
            aria-label={social.name}
          >
            <Fragment set:html={social.icon} />
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>
