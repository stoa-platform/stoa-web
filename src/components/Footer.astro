---
const footerLinks = {
  product: [
    { label: 'Features', href: '#features' },
    { label: 'Pricing', href: '#pricing' },
    { label: 'Comparison', href: '#comparison' },
    { label: 'Changelog', href: 'https://github.com/stoa-platform/stoa/releases' },
    { label: 'Roadmap', href: 'https://docs.gostoa.dev/docs/roadmap' },
  ],
  resources: [
    { label: 'Documentation', href: 'https://docs.gostoa.dev/docs/intro' },
    { label: 'Architecture', href: 'https://docs.gostoa.dev/docs/concepts/architecture' },
    { label: 'API Reference', href: 'https://docs.gostoa.dev/docs/api/control-plane' },
    { label: 'Roadmap', href: 'https://docs.gostoa.dev/docs/roadmap' },
  ],
  community: [
    { label: 'GitHub', href: 'https://github.com/stoa-platform/stoa' },
    { label: 'Discord', href: 'https://discord.gg/j8tHSSes' },
    { label: 'Give Feedback', href: '/feedback' },
    { label: 'Contact', href: 'mailto:hello@gostoa.dev' },
  ],
};

