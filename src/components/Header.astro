---
import { getLangFromUrl, useTranslations, getAlternateUrl, getLocalizedHref, languages } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<nav class="nav" id="nav">
  <div class="nav-inner">
    <a href={getLocalizedHref(lang, '/')} class="nav-logo">
      <svg width="28" height="28" viewBox="0 0 32 32">
        <defs><linearGradient id="logo-grad" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" style="stop-color:#047857"/><stop offset="100%" style="stop-color:#059669"/></linearGradient></defs>
        <circle cx="16" cy="16" r="15" fill="url(#logo-grad)"/>
        <path d="M10 11 Q10 8, 16 8 Q22 8, 22 11 Q22 14, 16 14 Q10 14, 10 17 Q10 20, 16 20 Q22 20, 22 24 Q22 27, 16 27" stroke="white" stroke-width="2.5" stroke-linecap="round" fill="none"/>
        <circle cx="8" cy="14" r="1.5" fill="white" opacity="0.8"/><circle cx="24" cy="14" r="1.5" fill="white" opacity="0.8"/>
        <circle cx="8" cy="20" r="1.5" fill="white" opacity="0.8"/><circle cx="24" cy="20" r="1.5" fill="white" opacity="0.8"/>
      </svg>
      <span>STOA</span>
    </a>
    <div class="nav-links">
      <a href="#features">{t('header.features')}</a>
      <a href="https://docs.gostoa.dev" target="_blank" rel="noopener">{t('header.docs')}</a>
      <a href="https://docs.gostoa.dev/docs/community" target="_blank" rel="noopener">{t('header.community')}</a>
      <a href="https://docs.gostoa.dev/docs/enterprise/use-cases" target="_blank" rel="noopener">{t('header.enterprise')}</a>
      <a href={getLocalizedHref(lang, '/pricing')}>{t('header.pricing')}</a>
      <a href="https://github.com/stoa-platform" target="_blank" rel="noopener">{t('header.github')}</a>
    </div>
    <div class="nav-right">
      <a href={getAlternateUrl(Astro.url, lang === 'en' ? 'fr' : 'en')} class="nav-lang" aria-label={lang === 'en' ? 'Passer en français' : 'Switch to English'}>
        {lang === 'en' ? 'FR' : 'EN'}
      </a>
      <a href="https://portal.gostoa.dev" class="nav-cta">{t('header.tryFree')}</a>
      <button class="mobile-menu-toggle" aria-label="Toggle menu" aria-expanded="false">
        <svg class="mobile-menu-icon-open" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        <svg class="mobile-menu-icon-close" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
  </div>
</nav>

<div class="mobile-menu" id="mobile-menu">
  <div class="mobile-menu-inner">
    <a href="#features">{t('header.features')}</a>
    <a href="https://docs.gostoa.dev" target="_blank" rel="noopener">{t('header.docs')}</a>
    <a href="https://docs.gostoa.dev/docs/community" target="_blank" rel="noopener">{t('header.community')}</a>
    <a href="https://docs.gostoa.dev/docs/enterprise/use-cases" target="_blank" rel="noopener">{t('header.enterprise')}</a>
    <a href={getLocalizedHref(lang, '/pricing')}>{t('header.pricing')}</a>
    <a href="https://github.com/stoa-platform" target="_blank" rel="noopener">{t('header.github')}</a>
    <div class="mobile-menu-footer">
      <a href={getAlternateUrl(Astro.url, lang === 'en' ? 'fr' : 'en')} class="nav-lang">
        {lang === 'en' ? 'FR' : 'EN'}
      </a>
      <a href="https://portal.gostoa.dev" class="btn-primary">{t('header.tryFree')}</a>
    </div>
  </div>
</div>
