---
import { getLocaleFromUrl, getLocalePath, getAlternateLocale, t } from '../i18n/index';

const locale = getLocaleFromUrl(Astro.url);
const i18n = t(locale);
const altLocale = getAlternateLocale(locale);
const currentPath = Astro.url.pathname.replace(/^\/fr/, '') || '/';
const altUrl = getLocalePath(currentPath, altLocale);
---

<nav class="nav" id="nav">
  <div class="nav-inner">
    <a href={getLocalePath('/', locale)} class="nav-logo">
      <svg width="28" height="28" viewBox="0 0 32 32">
        <defs><linearGradient id="logo-grad" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" style="stop-color:#047857"/><stop offset="100%" style="stop-color:#059669"/></linearGradient></defs>
        <circle cx="16" cy="16" r="15" fill="url(#logo-grad)"/>
        <path d="M10 11 Q10 8, 16 8 Q22 8, 22 11 Q22 14, 16 14 Q10 14, 10 17 Q10 20, 16 20 Q22 20, 22 24 Q22 27, 16 27" stroke="white" stroke-width="2.5" stroke-linecap="round" fill="none"/>
        <circle cx="8" cy="14" r="1.5" fill="white" opacity="0.8"/><circle cx="24" cy="14" r="1.5" fill="white" opacity="0.8"/>
        <circle cx="8" cy="20" r="1.5" fill="white" opacity="0.8"/><circle cx="24" cy="20" r="1.5" fill="white" opacity="0.8"/>
      </svg>
      <span>STOA</span>
    </a>
    <div class="nav-links">
      <a href="#features">{i18n.nav.features}</a>
      <a href="#architecture">{i18n.nav.architecture}</a>
      <a href="#ttfac">{i18n.nav.ttfac}</a>
      <a href={getLocalePath('/pricing', locale)}>{i18n.nav.pricing}</a>
      <a href="https://docs.gostoa.dev" target="_blank" rel="noopener">{i18n.nav.docs}</a>
      <a href="https://github.com/stoa-platform/stoa" target="_blank" rel="noopener">{i18n.nav.github}</a>
      <a href={altUrl} class="nav-lang" title={altLocale === 'fr' ? 'Passer en fran\u00e7ais' : 'Switch to English'}>
        {altLocale === 'fr' ? 'FR' : 'EN'}
      </a>
    </div>
    <a href="https://portal.gostoa.dev" class="nav-cta">{i18n.nav.tryFree}</a>
  </div>
</nav>
