---
import { getLocaleFromUrl, t } from '../i18n/index';

const locale = getLocaleFromUrl(Astro.url);
const i18n = t(locale);
---

<section class="architecture" id="architecture" aria-label="Architecture Diagram">
  <div class="section-container">
    <div class="section-header reveal" data-reveal>
      <span class="section-tag">{i18n.architecture.sectionTag}</span>
      <h2 class="section-title" set:html={i18n.architecture.title} />
      <p class="section-desc">{i18n.architecture.desc}</p>
    </div>

    <div class="arch-diagram" data-stagger-parent>
      <div class="arch-layer stagger-child" data-stagger="0">
        <div class="arch-layer-title arch-cloud">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 10h-1.26A8 8 0 109 20h9a5 5 0 000-10z"/></svg>
          {i18n.architecture.cloud}
        </div>
        <div class="arch-nodes">
          {i18n.architecture.cloudNodes.map((node: string) => (
            <div class="arch-node">{node}</div>
          ))}
        </div>
      </div>

      <div class="arch-bridge stagger-child" data-stagger="1">
        {i18n.architecture.connectors.map((c: { label: string; color: string }, i: number) => (
          <div class={`arch-lane arch-lane-${c.color}`}>
            <div class="arch-lane-line">
              <div class="arch-pulse arch-pulse-down" style={`animation-delay: ${i * 0.6}s`}></div>
              <div class="arch-pulse arch-pulse-up" style={`animation-delay: ${i * 0.6 + 1.2}s`}></div>
            </div>
            <span class="arch-lane-label">{c.label}</span>
          </div>
        ))}
      </div>

      <div class="arch-layer stagger-child" data-stagger="2">
        <div class="arch-layer-title arch-onprem">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><circle cx="6" cy="6" r="1"/><circle cx="6" cy="18" r="1"/></svg>
          {i18n.architecture.onPremise}
        </div>
        <div class="arch-nodes">
          {i18n.architecture.onpremNodes.map((node: string) => (
            <div class="arch-node">{node}</div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
