---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const standards = [
  { label: t('standards.ietf'), sub: t('standards.ietf.sub'), cls: 'si-ietf', icon: '\uD83D\uDD10' },
  { label: t('standards.oidc'), sub: t('standards.oidc.sub'), cls: 'si-oidc', icon: '\uD83D\uDD11' },
  { label: t('standards.keycloak'), sub: t('standards.keycloak.sub'), cls: 'si-cncf', icon: '\uD83D\uDEE1\uFE0F' },
  { label: t('standards.prometheus'), sub: t('standards.prometheus.sub'), cls: 'si-prom', icon: '\uD83D\uDCCA' },
  { label: t('standards.mcp'), sub: t('standards.mcp.sub'), cls: 'si-mcp', icon: '\u2699\uFE0F' },
  { label: t('standards.apache'), sub: t('standards.apache.sub'), cls: 'si-apache', icon: '\uD83D\uDCC4' },
];
---

<section class="standards" id="standards" aria-label="Standards and Compliance">
  <div class="section-container">
    <div class="section-header reveal" data-reveal>
      <span class="section-tag">{t('standards.tag')}</span>
      <h2 class="section-title" set:html={t('standards.title')} />
    </div>

    <div class="standards-row reveal" data-reveal data-reveal-delay="100">
      {standards.map((s) => (
        <div class="standard-badge">
          <div class={`standard-icon ${s.cls}`}>{s.icon}</div>
          <div class="standard-text">{s.label}<br /><span style="color: var(--text-muted); font-weight: 400;">{s.sub}</span></div>
        </div>
      ))}
    </div>
  </div>
</section>
