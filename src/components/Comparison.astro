---
// Paradigm comparison - Strategic dimensions, not features
const dimensions = [
  {
    dimension: 'Design Philosophy',
    incumbents: 'Gateway-centric (add AI later)',
    stoa: 'Agent-centric (AI-first, APIs included)',
    icon: '👤'
  },
  { 
    dimension: 'Design Paradigm', 
    incumbents: 'Spec-centric (OpenAPI)', 
    stoa: 'Contract-centric (UAC)',
    icon: '📐'
  },
  { 
    dimension: 'Protocol Strategy', 
    incumbents: 'REST-first, others as add-ons', 
    stoa: 'Protocol-agnostic native',
    icon: '🔌'
  },
  { 
    dimension: 'API Discovery', 
    incumbents: 'Portal + documentation', 
    stoa: 'MCP tools + Portal',
    icon: '🔍'
  },
  {
    dimension: 'AI Observability',
    incumbents: 'Retrofitted (plugin-based)',
    stoa: 'Native (built-in from day 1)',
    icon: '📊'
  },
  {
    dimension: 'Data Sovereignty',
    incumbents: 'Varies by vendor',
    stoa: 'European (NIS2/DORA supportive)',
    icon: '🇪🇺'
  },
  { 
    dimension: 'Open Source Model', 
    incumbents: 'Open-core with restrictions', 
    stoa: 'Apache 2.0 / Cloud Native',
    icon: '🔓'
  },
];

// Feature comparison — verified February 2026
const features = [
  { name: 'MCP-Native Architecture', stoa: true, kong: 'no:Plugin', tyk: 'no:Add-on', gravitee: 'no:Add-on', apisix: 'no:Plugin' },
  { name: 'Universal API Contract (UAC)', stoa: true, kong: false, tyk: false, gravitee: false, apisix: false },
  { name: 'Legacy Gateway Orchestration', stoa: true, kong: false, tyk: false, gravitee: 'partial', apisix: false },
  { name: 'European Sovereign', stoa: true, kong: 'no:US', tyk: 'no:UK', gravitee: 'yes:FR/EU', apisix: 'no:CN/Apache' },
  { name: 'True Open Source (no open-core)', stoa: true, kong: 'partial', tyk: 'partial', gravitee: 'partial', apisix: true },
  { name: 'On-Premise Control Plane', stoa: true, kong: 'no:Konnect', tyk: 'no:Tyk Cloud', gravitee: 'no:Gravitee Cloud', apisix: true },
  { name: 'Multi-Tenant Native', stoa: true, kong: 'partial', tyk: false, gravitee: false, apisix: 'partial' },
  { name: 'Kubernetes CRD-Native', stoa: true, kong: true, tyk: false, gravitee: false, apisix: true },
  { name: 'AI Token Metering', stoa: true, kong: true, tyk: true, gravitee: true, apisix: true },
];

const competitors = [
  { key: 'stoa', name: 'STOA', highlight: true },
  { key: 'kong', name: 'Kong' },
  { key: 'tyk', name: 'Tyk' },
  { key: 'gravitee', name: 'Gravitee' },
  { key: 'apisix', name: 'APISIX' },
];

const differentiators = [
  {
    icon: '🤖',
    title: 'MCP-Native',
    subtitle: 'Purpose-built for AI agents from day one',
    description: 'Every major gateway now offers MCP plugins. STOA is the only one built MCP-native from day one — no plugins to install, no add-ons to configure, no protocol translation layer.',
  },
  {
    icon: '📜',
    title: 'Universal API Contract',
    subtitle: 'Define once, expose everywhere',
    description: 'One contract definition exposes your API across REST and MCP. No duplication, no drift, no maintenance nightmare.',
  },
  {
    icon: '🇪🇺',
    title: 'European Sovereign',
    subtitle: 'European jurisdiction. Your rules.',
    description: 'Built in France, hosted in Europe. Your data stays under European jurisdiction when deployed on European infrastructure.*',
  },
  {
    icon: '🔓',
    title: 'True Open Source',
    subtitle: 'Sustainable open source model',
    description: 'Apache 2.0 licensed with a commitment to long-term sustainability. No bait-and-switch, no open-core restrictions on essential features.',
  },
];

function renderValue(value: boolean | string) {
  const checkIcon = `<svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>`;
  const xIcon = `<svg class="w-5 h-5 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>`;

  if (value === true) {
    return checkIcon;
  } else if (value === false) {
    return xIcon;
  } else if (value === 'partial') {
    return `<span class="text-yellow-500 text-xs font-medium">Partial</span>`;
  } else if (typeof value === 'string' && value.startsWith('no:')) {
    const label = value.substring(3);
    return `<div class="flex flex-col items-center gap-0.5">${xIcon}<span class="text-gray-500 text-[10px]">${label}</span></div>`;
  } else if (typeof value === 'string' && value.startsWith('yes:')) {
    const label = value.substring(4);
    return `<div class="flex flex-col items-center gap-0.5">${checkIcon}<span class="text-green-400 text-[10px]">${label}</span></div>`;
  }
  return value;
}
---

<section id="comparison" class="py-24 bg-gray-950">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- ============================================ -->
    <!-- PART 1: Paradigm Shift Header               -->
    <!-- ============================================ -->
    <div class="text-center mb-20">
      <span class="text-primary-400 font-semibold text-sm uppercase tracking-wider">The Paradigm Shift</span>
      <h2 class="text-3xl sm:text-4xl font-bold text-white mt-2 mb-6">
        From Human-First to <span class="gradient-text">Agent-First</span>
      </h2>
      
      <!-- TTFAC comparison -->
      <div class="max-w-4xl mx-auto">
        <div class="grid md:grid-cols-2 gap-6 mt-10">
          <!-- Incumbents -->
          <div class="p-6 bg-gray-900 border border-gray-800 rounded-xl">
            <div class="text-gray-500 text-sm uppercase tracking-wider mb-2">Traditional Gateways</div>
            <div class="text-2xl font-bold text-gray-300 mb-3">
              Optimize for <span class="text-amber-400">TTFAC</span>
            </div>
            <div class="text-gray-400">
              Time To First <span class="text-white font-medium">API</span> Call
            </div>
            <div class="mt-4 text-sm text-gray-500">
              Portal → Read docs → Get key → Write code → First call
            </div>
          </div>
          
          <!-- STOA -->
          <div class="p-6 bg-primary-900/20 border border-primary-600/50 rounded-xl">
            <div class="text-primary-400 text-sm uppercase tracking-wider mb-2">STOA Platform</div>
            <div class="text-2xl font-bold text-white mb-3">
              Optimizes for <span class="text-primary-400">TTFAC</span>
            </div>
            <div class="text-gray-300">
              Time To First <span class="text-primary-400 font-medium">Agent</span> Call
            </div>
            <div class="mt-4 text-sm text-gray-400">
              MCP discover → Agent understands → Governed call → Done
            </div>
          </div>
        </div>
        
        <p class="text-gray-500 mt-8 text-lg italic">
          "The same acronym. A completely different world."
        </p>
      </div>
    </div>

    <!-- ============================================ -->
    <!-- PART 2: Strategic Dimensions Table          -->
    <!-- ============================================ -->
    <div class="mb-20">
      <div class="text-center mb-10">
        <h3 class="text-2xl font-bold text-white">
          How We <span class="gradient-text">Think Differently</span>
        </h3>
        <p class="text-gray-400 mt-2">Strategic dimensions, not feature checklists</p>
      </div>
      
      <div class="overflow-x-auto">
        <table class="w-full min-w-[700px]">
          <thead>
            <tr class="border-b border-gray-800">
              <th class="text-left py-4 px-4 text-gray-400 font-medium text-sm w-1/4">Dimension</th>
              <th class="text-left py-4 px-4 text-gray-400 font-medium text-sm w-1/3">
                <span class="flex items-center gap-2">
                  <span class="text-gray-500">Kong, Tyk, APISIX...</span>
                </span>
              </th>
              <th class="text-left py-4 px-4 text-sm w-1/3 bg-primary-600/10">
                <span class="text-primary-400 font-semibold">STOA</span>
              </th>
            </tr>
          </thead>
          <tbody>
            {dimensions.map((row, index) => (
              <tr class={`border-b border-gray-800/50 ${index % 2 === 0 ? 'bg-gray-900/30' : ''}`}>
                <td class="py-4 px-4">
                  <div class="flex items-center gap-3">
                    <span class="text-xl">{row.icon}</span>
                    <span class="text-gray-300 font-medium">{row.dimension}</span>
                  </div>
                </td>
                <td class="py-4 px-4 text-gray-500">{row.incumbents}</td>
                <td class="py-4 px-4 text-white bg-primary-600/5 font-medium">{row.stoa}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- ============================================ -->
    <!-- PART 3: Key Differentiators Cards           -->
    <!-- ============================================ -->
    <div class="mb-20">
      <div class="text-center mb-10">
        <h3 class="text-2xl font-bold text-white">
          What Makes STOA <span class="gradient-text">Different</span>
        </h3>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {differentiators.map((item) => (
          <div class="p-6 bg-gray-900 border border-gray-800 rounded-xl hover:border-primary-600/50 transition-all duration-300">
            <div class="text-4xl mb-4">{item.icon}</div>
            <h4 class="text-xl font-bold text-white mb-1">{item.title}</h4>
            <div class="text-primary-400 text-sm font-medium mb-3">{item.subtitle}</div>
            <p class="text-gray-400 text-sm">{item.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- ============================================ -->
    <!-- PART 4: Detailed Feature Comparison         -->
    <!-- ============================================ -->
    <div>
      <div class="text-center mb-10">
        <h3 class="text-2xl font-bold text-white">
          Feature-by-Feature <span class="gradient-text">Comparison</span>
        </h3>
        <p class="text-gray-400 mt-2">For the detail-oriented among us</p>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full min-w-[800px]">
          <thead>
            <tr class="border-b border-gray-800">
              <th class="text-left py-4 px-4 text-gray-400 font-medium text-sm">Feature</th>
              {competitors.map((competitor) => (
                <th class={`py-4 px-4 text-center ${competitor.highlight ? 'bg-primary-600/10' : ''}`}>
                  <span class={`font-semibold ${competitor.highlight ? 'text-primary-400' : 'text-gray-300'}`}>
                    {competitor.name}
                  </span>
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {features.map((feature, index) => (
              <tr class={`border-b border-gray-800/50 ${index % 2 === 0 ? 'bg-gray-900/30' : ''}`}>
                <td class="py-4 px-4 text-gray-300 text-sm">{feature.name}</td>
                {competitors.map((competitor) => (
                  <td class={`py-4 px-4 text-center ${competitor.highlight ? 'bg-primary-600/5' : ''}`}>
                    <div class="flex justify-center">
                      <Fragment set:html={renderValue(feature[competitor.key as keyof typeof feature] as boolean | string)} />
                    </div>
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Sovereignty note -->
      <div class="mt-8 p-4 bg-primary-900/20 border border-primary-600/30 rounded-lg">
        <div class="flex items-start gap-3">
          <span class="text-2xl">🇪🇺</span>
          <div>
            <h4 class="text-white font-semibold">Why European Sovereignty Matters</h4>
            <p class="text-gray-400 text-sm mt-1">
              Kong (US), Tyk (UK post-Brexit), APISIX (China/Apache) are subject to foreign jurisdiction.
              Gravitee is European but operates an open-core model with cloud-first SaaS.
              STOA is the only fully open-source (Apache 2.0), on-premise-first European alternative — relevant for banks, public sector, and regulated industries with NIS2/DORA requirements.
            </p>
          </div>
        </div>
      </div>

      <!-- Bottom note -->
      <div class="mt-6 text-center">
        <p class="text-gray-500 text-sm">
          Feature comparisons are based on publicly available documentation, last verified February 2026. Product capabilities change frequently.
          We encourage readers to verify current features directly with each vendor.
          All trademarks belong to their respective owners. We welcome corrections — contact hello@gostoa.dev
          <a href="https://docs.gostoa.dev/blog/kong-vs-stoa-mcp-gateway" class="text-primary-400 hover:text-primary-300 ml-1">
            View full comparison →
          </a>
        </p>
      </div>
    </div>

  </div>
</section>
