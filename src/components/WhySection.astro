---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const problems = [
  { title: t('why.problem1.title'), description: t('why.problem1.description') },
  { title: t('why.problem2.title'), description: t('why.problem2.description') },
  { title: t('why.problem3.title'), description: t('why.problem3.description') },
];
---

<section id="why" class="py-24 bg-gray-900/50">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl sm:text-4xl font-bold text-center text-white mb-12">{t('why.title')}</h2>

    <div class="space-y-8 text-lg text-gray-300">
      {problems.map((p) => (
        <div class="flex gap-4">
          <span class="text-red-400 text-2xl shrink-0">X</span>
          <div>
            <h3 class="font-semibold text-white mb-2">{p.title}</h3>
            <p>{p.description}</p>
          </div>
        </div>
      ))}

      <!-- Solution -->
      <div class="mt-12 p-6 bg-gray-800 rounded-xl border border-green-800/50">
        <div class="flex gap-4">
          <span class="text-green-400 text-2xl shrink-0">
            <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </span>
          <div>
            <h3 class="font-semibold text-white mb-2">{t('why.solution.title')}</h3>
            <p>{t('why.solution.description')}</p>
          </div>
        </div>
      </div>

      <!-- Tagline -->
      <p class="text-center text-xl text-gray-400 mt-12 italic">
        "{t('why.tagline').split('. ')[0]}. <span class="text-white font-medium">{t('why.tagline').split('. ')[1]}</span>"
      </p>
    </div>
  </div>
</section>
