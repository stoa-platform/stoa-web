---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const cards = [
  {
    icon: '\u26A1',
    title: t('differentiators.mcp.title'),
    subtitle: t('differentiators.mcp.subtitle'),
    desc: t('differentiators.mcp.description'),
  },
  {
    icon: '\uD83D\uDD17',
    title: t('differentiators.uac.title'),
    subtitle: t('differentiators.uac.subtitle'),
    desc: t('differentiators.uac.description'),
  },
  {
    icon: '\uD83C\uDDEA\uD83C\uDDFA',
    title: t('differentiators.sovereign.title'),
    subtitle: t('differentiators.sovereign.subtitle'),
    desc: t('differentiators.sovereign.description'),
  },
  {
    icon: '\uD83D\uDD13',
    title: t('differentiators.oss.title'),
    subtitle: t('differentiators.oss.subtitle'),
    desc: t('differentiators.oss.description'),
  },
];
---

<section class="differentiators" id="differentiators" aria-label="Key Differentiators">
  <div class="section-container">
    <div class="section-header reveal" data-reveal>
      <span class="section-tag">{t('differentiators.tag')}</span>
      <h2 class="section-title" set:html={t('differentiators.title')} />
      <p class="section-desc">{t('differentiators.description')}</p>
    </div>

    <div class="diff-grid" data-stagger-parent>
      {cards.map((card, i) => (
        <div class="diff-card stagger-child" data-stagger={i}>
          <div class="diff-icon">{card.icon}</div>
          <h3 class="diff-title">{card.title}</h3>
          <p class="diff-subtitle">{card.subtitle}</p>
          <p class="diff-desc">{card.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
