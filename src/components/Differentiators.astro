---
import { getLocaleFromUrl, t } from '../i18n/index';

const locale = getLocaleFromUrl(Astro.url);
const i18n = t(locale);
---

<section class="differentiators" id="differentiators" aria-label="Key Differentiators">
  <div class="section-container">
    <div class="section-header reveal" data-reveal>
      <span class="section-tag">{i18n.differentiators.sectionTag}</span>
      <h2 class="section-title" set:html={i18n.differentiators.title} />
      <p class="section-desc">{i18n.differentiators.desc}</p>
    </div>

    <div class="diff-grid" data-stagger-parent>
      {i18n.differentiators.cards.map((card: { icon: string; title: string; subtitle: string; desc: string }, i: number) => (
        <div class="diff-card stagger-child" data-stagger={i}>
          <div class="diff-icon">{card.icon}</div>
          <h3 class="diff-title">{card.title}</h3>
          <p class="diff-subtitle">{card.subtitle}</p>
          <p class="diff-desc">{card.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
