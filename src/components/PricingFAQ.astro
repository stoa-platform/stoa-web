---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const faqs = [
  { question: t('pricingFaq.q1'), answer: t('pricingFaq.a1') },
  { question: t('pricingFaq.q2'), answer: t('pricingFaq.a2') },
  { question: t('pricingFaq.q3'), answer: t('pricingFaq.a3') },
  { question: t('pricingFaq.q4'), answer: t('pricingFaq.a4') },
  { question: t('pricingFaq.q5'), answer: t('pricingFaq.a5') },
  { question: t('pricingFaq.q6'), answer: t('pricingFaq.a6') },
  { question: t('pricingFaq.q7'), answer: t('pricingFaq.a7') },
];
---

<section class="faq-section" id="faq">
  <div class="section-container">
    <div class="section-header reveal" data-reveal>
      <h2 class="section-title">{t('pricingFaq.title')}</h2>
      <p class="section-desc">{t('pricingFaq.description')}</p>
    </div>

    <div class="faq-list">
      {faqs.map((faq) => (
        <details class="faq-item reveal" data-reveal>
          <summary>
            <span>{faq.question}</span>
            <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="faq-answer">{faq.answer}</div>
        </details>
      ))}
    </div>

    <div class="faq-contact reveal" data-reveal>
      <p>{t('pricingFaq.footer')} <a href="mailto:hello@gostoa.dev">hello@gostoa.dev</a></p>
    </div>
  </div>
</section>
