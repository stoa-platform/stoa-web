---
import { getLocaleFromUrl, t } from '../i18n/index';

const locale = getLocaleFromUrl(Astro.url);
const i18n = t(locale);
---

<section class="faq-section" id="faq">
  <div class="section-container">
    <div class="section-header reveal" data-reveal>
      <h2 class="section-title">{i18n.faq.title}</h2>
      <p class="section-desc">{i18n.faq.desc}</p>
    </div>

    <div class="faq-list">
      {i18n.faq.items.map((faq: { question: string; answer: string }) => (
        <details class="faq-item reveal" data-reveal>
          <summary>
            <span>{faq.question}</span>
            <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="faq-answer">{faq.answer}</div>
        </details>
      ))}
    </div>

    <div class="faq-contact reveal" data-reveal>
      <p>{i18n.faq.contact} <a href="mailto:hello@gostoa.dev">{i18n.faq.contactLink}</a></p>
    </div>
  </div>
</section>
